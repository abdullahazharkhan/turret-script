[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/ui/ide_panel.gd" id="1_a2b3c"]
[ext_resource type="Texture2D" path="res://assets/ui/icons/icon_compile.png" id="2_icomp"]
[ext_resource type="Texture2D" path="res://assets/ui/icons/icon_run.png" id="3_irun"]
[ext_resource type="Texture2D" path="res://assets/ui/icons/icon_step.png" id="4_istep"]

[node name="IDEPanel" type="PanelContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_a2b3c")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="Toolbar" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="CompileButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Compile"
icon = ExtResource("2_icomp")

[node name="RunButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Run"
icon = ExtResource("3_irun")

[node name="StepStageButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Step Stage"
icon = ExtResource("4_istep")

[node name="ResetButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Reset"

[node name="VSeparator" type="VSeparator" parent="VBoxContainer/Toolbar"]
layout_mode = 2

[node name="ExamplesOption" type="OptionButton" parent="VBoxContainer/Toolbar"]
layout_mode = 2

[node name="SaveButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Save"

[node name="LoadButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Load"

[node name="HelpButton" type="Button" parent="VBoxContainer/Toolbar"]
layout_mode = 2
text = "Help"

[node name="CodeEditor" type="CodeEdit" parent="VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
text = "func main() {
	var enemies = get_enemies();
	var target = nearest(enemies);
	if (distance(target) < 200) {
		shoot(target);
	}
}"
gutters_draw_line_numbers = true
auto_brace_completion_enabled = true

[node name="StatusBar" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="LineColLabel" type="Label" parent="VBoxContainer/StatusBar"]
layout_mode = 2
text = "Line: 1, Col: 1"

[node name="DiagnosticsPanel" type="RichTextLabel" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 100)
layout_mode = 2
bbcode_enabled = true
text = "No errors."

[node name="HelpDialog" type="AcceptDialog" parent="."]
title = "TurretScript Reference"
initial_position = 2
size = Vector2i(600, 400)

[node name="HelpText" type="RichTextLabel" parent="HelpDialog"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 8.0
offset_top = 8.0
offset_right = -8.0
offset_bottom = -49.0
grow_horizontal = 2
grow_vertical = 2
bbcode_enabled = true
text = "[b]Types:[/b] int, bool, string, enemy, void
[b]Variables:[/b] var x = 5; int y = 10;
[b]Control Flow:[/b] if (cond) { }, while (cond) { }, for enemy e in get_enemies() { }

[b]Built-in API:[/b]
- [color=#d2a8ff]get_enemies()[/color] -> array of enemies
- [color=#d2a8ff]nearest(enemies_array)[/color] -> enemy
- [color=#d2a8ff]distance(enemy)[/color] -> int
- [color=#d2a8ff]shoot(enemy)[/color] -> void
- [color=#d2a8ff]reload()[/color] -> void

[b]Enemy Properties:[/b]
- [color=#ffcc00]enemy.id[/color] (int)
- [color=#ffcc00]enemy.health[/color] (int)
- [color=#ffcc00]enemy.type[/color] (string: 'scout', 'tank', etc)
- [color=#ffcc00]enemy.alive[/color] (bool)"
